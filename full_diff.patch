+"use client";
+
+import { ArrowRight, Wind, BarChart3, Building2, Scale } from "lucide-react";
+import { cn } from "@/lib/utils";
+import { useLabStore } from "../../store/use-lab-store";
+import type { PreprocessConfig } from "../../types";
+
+// ─── Pipeline Steps ─────────────────────────────────────
+
+const PIPELINE_STEPS: {
+  key: keyof PreprocessConfig;
+  label: string;
+  desc: string;
+  icon: typeof Wind;
+}[] = [
+  {
+    key: "winsorize",
+    label: "去极值",
+    desc: "MAD 方法截断异常值",
+    icon: Wind,
+  },
+  {
+    key: "standardize",
+    label: "标准化",
+    desc: "Z-Score 归一化",
+    icon: BarChart3,
+  },
+  {
+    key: "industryNeutral",
+    label: "行业中性化",
+    desc: "回归剔除行业效应",
+    icon: Building2,
+  },
+  {
+    key: "capNeutral",
+    label: "市值中性化",
+    desc: "回归剔除市值效应",
+    icon: Scale,
+  },
+];
+
+// ─── Preprocessing Tab ──────────────────────────────────
+
+export function PreprocessingTab() {
+  const config = useLabStore((s) => s.preprocessConfig);
+  const toggleStep = useLabStore((s) => s.togglePreprocessStep);
+
+  return (
+    <div
+      data-slot="preprocessing-tab"
+      className="h-full flex items-start justify-center pt-8 p-6"
+    >
+      <div className="flex items-center gap-2">
+        {PIPELINE_STEPS.map((step, idx) => {
+          const active = config[step.key];
+          const Icon = step.icon;
+
+          return (
+            <div key={step.key} className="flex items-center gap-2">
+              {/* Step card */}
+              <button
+                type="button"
+                onClick={() => toggleStep(step.key)}
+                className={cn(
+                  "flex flex-col items-center gap-2 p-3 w-[140px] rounded-xl border transition-all",
+                  active
+                    ? "border-mine-accent-teal/30 bg-mine-accent-teal/5"
+                    : "border-mine-border bg-white hover:border-mine-border/80",
+                )}
+              >
+                {/* Toggle indicator */}
+                <div className="flex items-center justify-between w-full">
+                  <Icon
+                    className={cn(
+                      "w-4 h-4",
+                      active ? "text-mine-accent-teal" : "text-mine-muted",
+                    )}
+                  />
+                  <div
+                    className={cn(
+                      "w-7 h-3.5 rounded-full transition-colors relative",
+                      active ? "bg-mine-accent-teal" : "bg-mine-border",
+                    )}
+                  >
+                    <span
+                      className={cn(
+                        "absolute top-0.5 w-2.5 h-2.5 rounded-full bg-white shadow-sm transition-transform",
+                        active ? "translate-x-3.5" : "translate-x-0.5",
+                      )}
+                    />
+                  </div>
+                </div>
+
+                <div className="text-center">
+                  <div
+                    className={cn(
+                      "text-xs font-medium",
+                      active ? "text-mine-text" : "text-mine-muted",
+                    )}
+                  >
+                    {step.label}
+                  </div>
+                  <div className="text-[10px] text-mine-muted mt-0.5">
+                    {step.desc}
+                  </div>
+                </div>
+              </button>
+
+              {/* Arrow connector */}
+              {idx < PIPELINE_STEPS.length - 1 && (
+                <ArrowRight className="w-4 h-4 text-mine-muted/50 shrink-0" />
+              )}
+            </div>
+          );
+        })}
+      </div>
+    </div>
+  );
+}

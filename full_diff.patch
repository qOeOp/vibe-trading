+"use client";
+
+import { useMemo, useId } from "react";
+import { DetailSection } from "@/components/shared/detail-panel";
+import { LineChart } from "@/lib/ngx-charts/line-chart";
+import type { MultiSeries } from "@/lib/ngx-charts/types";
+import { computeCumulativeIC } from "../../../utils/compute-ic-stats";
+import type { Factor } from "../../../types";
+
+/* ── Visual constants ──────────────────────────────────────────── */
+
+const KNOCKOUT_COLOR = "#f5f3ef";
+
+const CUMULATIVE_COLORS: Array<{ name: string; value: string }> = [
+  { name: "累计IC", value: "#26a69a" },
+];
+
+const SERIES_CONFIG: Record<string, {
+  strokeWidth?: number;
+  knockoutColor?: string;
+  knockoutWidthMultiplier?: number;
+  shadowFilter?: string;
+  strokeLinecap?: "butt" | "round" | "square";
+  strokeLinejoin?: "miter" | "round" | "bevel";
+  strokeOpacity?: number;
+  areaFillOpacity?: number;
+}> = {
+  "累计IC": {
+    strokeWidth: 1.2,
+    knockoutColor: KNOCKOUT_COLOR,
+    knockoutWidthMultiplier: 2,
+    strokeLinecap: "round",
+    strokeLinejoin: "round",
+    strokeOpacity: 1,
+    areaFillOpacity: 0.10,
+  },
+};
+
+/* ── Chart Component ──────────────────────────────────────────── */
+
+function CumulativeICChart({ data }: { data: number[] }) {
+  if (!data || data.length === 0) return null;
+
+  const reactId = useId();
+  const shadowFilterId = `cum-ic-shadow${reactId.replace(/:/g, "")}`;
+
+  const chartData: MultiSeries = useMemo(() => {
+    const cumulative = computeCumulativeIC(data);
+    return [
+      {
+        name: "累计IC",
+        series: cumulative.map((v, i) => ({ name: i as number, value: v })),
+      },
+    ];
+  }, [data]);
+
+  const referenceLines = useMemo(
+    () => [{ name: "0", value: 0 }],
+    [],
+  );
+
+  const filterDefs = useMemo(
+    () => (
+      <filter id={shadowFilterId} x="-10%" y="-20%" width="120%" height="140%">
+        <feDropShadow dx="0" dy="0.5" stdDeviation="0.8" floodColor="#26a69a" floodOpacity="0.12" />
+      </filter>
+    ),
+    [shadowFilterId],
+  );
+
+  const seriesConfigWithId = useMemo(() => ({
+    ...SERIES_CONFIG,
+    "累计IC": {
+      ...SERIES_CONFIG["累计IC"],
+      shadowFilter: `url(#${shadowFilterId})`,
+    },
+  }), [shadowFilterId]);
+
+  return (
+    <LineChart
+      data={chartData}
+      customColors={CUMULATIVE_COLORS}
+      animated
+      showXAxis={false}
+      showYAxis
+      showGridLines={false}
+      showLegend={false}
+      autoScale
+      tooltipDisabled={false}
+      showRefLines
+      showRefLabels={false}
+      referenceLines={referenceLines}
+      roundDomains={false}
+      seriesConfig={seriesConfigWithId}
+      filterDefs={filterDefs}
+    />
+  );
+}
+
+/* ── Section Export ────────────────────────────────────────────── */
+
+interface ICCumulativeSectionProps {
+  factor: Factor;
+}
+
+export function ICCumulativeSection({ factor }: ICCumulativeSectionProps) {
+  return (
+    <DetailSection title="累计 IC">
+      <div className="h-[120px]">
+        <CumulativeICChart data={factor.icTimeSeries} />
+      </div>
+    </DetailSection>
+  );
+}

+"use client";
+
+import { useState, useRef, useEffect } from "react";
+import { X, Plus } from "lucide-react";
+import { cn } from "@/lib/utils";
+import { useLabStore } from "../../store/use-lab-store";
+
+// ─── File Tabs ──────────────────────────────────────────
+
+export function FileTabs() {
+  const files = useLabStore((s) => s.files);
+  const activeFileId = useLabStore((s) => s.activeFileId);
+  const setActiveFileId = useLabStore((s) => s.setActiveFileId);
+  const addFile = useLabStore((s) => s.addFile);
+  const removeFile = useLabStore((s) => s.removeFile);
+  const renameFile = useLabStore((s) => s.renameFile);
+
+  const [renamingId, setRenamingId] = useState<string | null>(null);
+  const [renameValue, setRenameValue] = useState("");
+  const renameInputRef = useRef<HTMLInputElement>(null);
+
+  // Focus rename input when entering rename mode
+  useEffect(() => {
+    if (renamingId && renameInputRef.current) {
+      renameInputRef.current.focus();
+      renameInputRef.current.select();
+    }
+  }, [renamingId]);
+
+  function handleDoubleClick(fileId: string, fileName: string) {
+    setRenamingId(fileId);
+    setRenameValue(fileName);
+  }
+
+  function commitRename() {
+    if (renamingId && renameValue.trim()) {
+      const finalName = renameValue.trim().endsWith(".py")
+        ? renameValue.trim()
+        : `${renameValue.trim()}.py`;
+      renameFile(renamingId, finalName);
+    }
+    setRenamingId(null);
+  }
+
+  function cancelRename() {
+    setRenamingId(null);
+  }
+
+  const canClose = files.length > 1;
+
+  return (
+    <div
+      data-slot="file-tabs"
+      className="flex items-center h-8 bg-mine-bg/30 border-b border-mine-border/30 px-1 shrink-0 overflow-x-auto"
+    >
+      {files.map((file) => {
+        const isActive = activeFileId === file.id;
+        const isRenaming = renamingId === file.id;
+
+        return (
+          <div
+            key={file.id}
+            className={cn(
+              "group flex items-center gap-1 h-7 px-2.5 text-xs font-medium rounded-t-md transition-colors cursor-pointer select-none shrink-0",
+              isActive
+                ? "bg-white text-mine-text border-b-2 border-mine-accent-teal"
+                : "text-mine-muted hover:text-mine-text hover:bg-white/50",
+            )}
+            onClick={() => !isRenaming && setActiveFileId(file.id)}
+            onDoubleClick={() => handleDoubleClick(file.id, file.name)}
+          >
+            {/* Dirty indicator */}
+            {file.isDirty && (
+              <span className="w-1.5 h-1.5 rounded-full bg-mine-accent-yellow shrink-0" />
+            )}
+
+            {/* File name or rename input */}
+            {isRenaming ? (
+              <input
+                ref={renameInputRef}
+                type="text"
+                value={renameValue}
+                onChange={(e) => setRenameValue(e.target.value)}
+                onBlur={commitRename}
+                onKeyDown={(e) => {
+                  if (e.key === "Enter") commitRename();
+                  if (e.key === "Escape") cancelRename();
+                }}
+                className="w-[80px] px-0.5 text-xs text-mine-text bg-white border border-mine-accent-teal/30 rounded outline-none"
+                onClick={(e) => e.stopPropagation()}
+              />
+            ) : (
+              <span className="truncate max-w-[100px]">{file.name}</span>
+            )}
+
+            {/* Close button */}
+            {canClose && !isRenaming && (
+              <button
+                type="button"
+                onClick={(e) => {
+                  e.stopPropagation();
+                  removeFile(file.id);
+                }}
+                className={cn(
+                  "w-3.5 h-3.5 flex items-center justify-center rounded-sm transition-colors shrink-0",
+                  isActive
+                    ? "opacity-60 hover:opacity-100 hover:bg-mine-border/50"
+                    : "opacity-0 group-hover:opacity-60 hover:!opacity-100 hover:bg-mine-border/50",
+                )}
+              >
+                <X className="w-2.5 h-2.5" />
+              </button>
+            )}
+          </div>
+        );
+      })}
+
+      {/* Add file button */}
+      <button
+        type="button"
+        onClick={() => addFile()}
+        className="flex items-center justify-center w-6 h-6 text-mine-muted hover:text-mine-text hover:bg-white/50 rounded-md transition-colors shrink-0 ml-0.5"
+        title="新建文件"
+      >
+        <Plus className="w-3.5 h-3.5" />
+      </button>
+    </div>
+  );
+}

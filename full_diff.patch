@@ -0,0 +1,106 @@
+"use client";
+
+import { useRef, useEffect, useCallback } from "react";
+import {
+  Group,
+  Panel,
+  Separator,
+  type PanelImperativeHandle,
+  type PanelSize,
+} from "react-resizable-panels";
+import { useLabStore } from "../../store/use-lab-store";
+import { EditorTabs } from "./editor-tabs";
+import { FileTabs } from "./file-tabs";
+import { CodeEditor } from "./code-editor";
+import { NotesTab } from "./notes-tab";
+import { PreprocessingTab } from "./preprocessing-tab";
+import { ConsoleOutput } from "../results/console-output";
+
+// ─── Horizontal Resize Handle (for vertical split) ──────
+
+function HorizontalResizeHandle() {
+  return (
+    <Separator className="group relative flex items-center justify-center h-1.5 shrink-0">
+      <div className="w-8 h-0.5 rounded-full bg-mine-border/50 group-hover:bg-mine-accent-teal group-active:bg-mine-accent-teal transition-colors" />
+    </Separator>
+  );
+}
+
+// ─── Editor Panel ───────────────────────────────────────
+
+export function EditorPanel() {
+  const activeTab = useLabStore((s) => s.activeTab);
+  const consolePanelOpen = useLabStore((s) => s.consolePanelOpen);
+  const setConsolePanelOpen = useLabStore((s) => s.setConsolePanelOpen);
+  const consolePanelRef = useRef<PanelImperativeHandle>(null);
+
+  // Sync store → panel imperative API
+  useEffect(() => {
+    const panel = consolePanelRef.current;
+    if (!panel) return;
+
+    if (consolePanelOpen) {
+      if (panel.isCollapsed()) {
+        panel.expand();
+      }
+    } else {
+      if (!panel.isCollapsed()) {
+        panel.collapse();
+      }
+    }
+  }, [consolePanelOpen]);
+
+  // Sync panel resize → store
+  const handleConsolePanelResize = useCallback(
+    (size: PanelSize) => {
+      const pct = size.asPercentage;
+      if (pct <= 0.5 && consolePanelOpen) {
+        setConsolePanelOpen(false);
+      } else if (pct > 0.5 && !consolePanelOpen) {
+        setConsolePanelOpen(true);
+      }
+    },
+    [consolePanelOpen, setConsolePanelOpen],
+  );
+
+  const isCodeTab = activeTab === "code";
+
+  return (
+    <div
+      data-slot="editor-panel"
+      className="h-full flex flex-col overflow-hidden"
+    >
+      <EditorTabs />
+      {isCodeTab && <FileTabs />}
+
+      <div className="flex-1 min-h-0 overflow-hidden">
+        {isCodeTab ? (
+          <Group orientation="vertical" className="h-full">
+            {/* Editor area */}
+            <Panel defaultSize={70} minSize={30}>
+              <CodeEditor />
+            </Panel>
+
+            {/* Console bottom panel — collapsible */}
+            <HorizontalResizeHandle />
+            <Panel
+              panelRef={consolePanelRef}
+              defaultSize={30}
+              minSize={15}
+              collapsible
+              collapsedSize={0}
+              onResize={handleConsolePanelResize}
+            >
+              <ConsoleOutput />
+            </Panel>
+          </Group>
+        ) : (
+          <>
+            {activeTab === "notes" && <NotesTab />}
+            {activeTab === "preprocessing" && <PreprocessingTab />}
+          </>
+        )}
+      </div>
+    </div>
+  );
+}

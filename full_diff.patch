+"use client";
+
+import { cn } from "@/lib/utils";
+import { useLabStore } from "../../store/use-lab-store";
+import type { EditorTab } from "../../types";
+
+// ─── Tab Config ─────────────────────────────────────────
+
+const TABS: { id: EditorTab; label: string }[] = [
+  { id: "code", label: "代码" },
+  { id: "notes", label: "笔记" },
+  { id: "preprocessing", label: "预处理" },
+];
+
+// ─── Editor Tabs ────────────────────────────────────────
+
+export function EditorTabs() {
+  const activeTab = useLabStore((s) => s.activeTab);
+  const setActiveTab = useLabStore((s) => s.setActiveTab);
+
+  return (
+    <div
+      data-slot="editor-tabs"
+      className="flex items-center h-9 border-b border-mine-border/50 px-3 shrink-0"
+    >
+      {TABS.map((tab) => {
+        const isActive = activeTab === tab.id;
+        return (
+          <button
+            key={tab.id}
+            type="button"
+            onClick={() => setActiveTab(tab.id)}
+            className={cn(
+              "px-3 py-2 text-xs font-medium transition-colors relative",
+              isActive
+                ? "text-mine-accent-teal"
+                : "text-mine-muted hover:text-mine-text",
+            )}
+          >
+            {tab.label}
+            {isActive && (
+              <span className="absolute bottom-0 left-3 right-3 h-0.5 bg-mine-accent-teal rounded-full" />
+            )}
+          </button>
+        );
+      })}
+    </div>
+  );
+}

+"use client";
+
+import {
+  BookOpen,
+  Minus,
+  Plus,
+  WrapText,
+  Search,
+  Maximize2,
+  Minimize2,
+} from "lucide-react";
+import { cn } from "@/lib/utils";
+import { useLabStore } from "../../store/use-lab-store";
+
+// ─── Editor Toolbar ─────────────────────────────────────
+
+interface EditorToolbarProps {
+  onOpenSearch?: () => void;
+}
+
+export function EditorToolbar({ onOpenSearch }: EditorToolbarProps) {
+  const fontSize = useLabStore((s) => s.editorFontSize);
+  const lineWrap = useLabStore((s) => s.editorLineWrap);
+  const contextCollapsed = useLabStore((s) => s.contextPanelCollapsed);
+  const setFontSize = useLabStore((s) => s.setEditorFontSize);
+  const toggleLineWrap = useLabStore((s) => s.toggleEditorLineWrap);
+  const setContextCollapsed = useLabStore((s) => s.setContextPanelCollapsed);
+
+  return (
+    <div
+      data-slot="editor-toolbar"
+      className="flex items-center h-8 px-2 gap-0.5 bg-mine-bg/50 border-b border-mine-border/30 shrink-0"
+    >
+      {/* API Docs */}
+      <ToolbarButton
+        icon={<BookOpen className="w-3.5 h-3.5" />}
+        label="API 文档"
+        title="因子函数 API 文档 (即将上线)"
+        disabled
+      />
+
+      <ToolbarSeparator />
+
+      {/* Font Size Controls */}
+      <ToolbarButton
+        icon={<Minus className="w-3 h-3" />}
+        title="缩小字号"
+        onClick={() => setFontSize(fontSize - 1)}
+        disabled={fontSize <= 12}
+      />
+      <span className="px-1.5 text-[10px] font-mono tabular-nums text-mine-muted select-none min-w-[28px] text-center">
+        {fontSize}px
+      </span>
+      <ToolbarButton
+        icon={<Plus className="w-3 h-3" />}
+        title="放大字号"
+        onClick={() => setFontSize(fontSize + 1)}
+        disabled={fontSize >= 18}
+      />
+
+      <ToolbarSeparator />
+
+      {/* Line Wrap Toggle */}
+      <ToolbarButton
+        icon={<WrapText className="w-3.5 h-3.5" />}
+        label="换行"
+        title={lineWrap ? "关闭自动换行" : "开启自动换行"}
+        active={lineWrap}
+        onClick={toggleLineWrap}
+      />
+
+      {/* Search */}
+      <ToolbarButton
+        icon={<Search className="w-3.5 h-3.5" />}
+        title="搜索 (⌘K)"
+        onClick={onOpenSearch}
+      />
+
+      {/* Spacer */}
+      <div className="flex-1" />
+
+      {/* Toggle right panel (maximize/restore editor) */}
+      <ToolbarButton
+        icon={
+          contextCollapsed ? (
+            <Minimize2 className="w-3.5 h-3.5" />
+          ) : (
+            <Maximize2 className="w-3.5 h-3.5" />
+          )
+        }
+        title={contextCollapsed ? "恢复面板" : "全屏编辑"}
+        active={contextCollapsed}
+        onClick={() => setContextCollapsed(!contextCollapsed)}
+      />
+    </div>
+  );
+}
+
+// ─── Sub-components ──────────────────────────────────────
+
+function ToolbarSeparator() {
+  return <div className="w-px h-4 bg-mine-border/40 mx-1" />;
+}
+
+interface ToolbarButtonProps {
+  icon: React.ReactNode;
+  label?: string;
+  title?: string;
+  active?: boolean;
+  disabled?: boolean;
+  onClick?: () => void;
+}
+
+function ToolbarButton({
+  icon,
+  label,
+  title,
+  active,
+  disabled,
+  onClick,
+}: ToolbarButtonProps) {
+  return (
+    <button
+      type="button"
+      title={title}
+      disabled={disabled}
+      onClick={onClick}
+      className={cn(
+        "flex items-center gap-1 px-1.5 py-1 rounded text-[10px] font-medium transition-colors",
+        disabled
+          ? "text-mine-muted/40 cursor-not-allowed"
+          : active
+            ? "bg-mine-accent-teal/10 text-mine-accent-teal"
+            : "text-mine-muted hover:text-mine-text hover:bg-mine-border/30",
+      )}
+    >
+      {icon}
+      {label && <span>{label}</span>}
+    </button>
+  );
+}
diff --git a/apps/web/src/features/lab/components/editor/extensions/create-extensions.ts b/apps/web/src/features/lab/components/editor/extensions/create-extensions.ts

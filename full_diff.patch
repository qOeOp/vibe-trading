@@ -0,0 +1,289 @@
+"use client";
+
+import { create } from "zustand";
+import { generateId } from "@/lib/id";
+import type {
+  ContextPanelTab,
+  ConsoleOutputLine,
+  EditorTab,
+  EditorStats,
+  LabFile,
+  PreprocessConfig,
+  PyodideStatus,
+  ValidationConfig,
+  ValidationResult,
+  ValidationStatus,
+  AIChatMessage,
+} from "../types";
+import {
+  DEFAULT_VALIDATION_CONFIG,
+  DEFAULT_PREPROCESS_CONFIG,
+} from "../types";
+import { createDefaultProject } from "../data/default-project";
+
+// ─── Initial Project ────────────────────────────────────
+
+const initialFiles = createDefaultProject();
+
+// ─── Store State ─────────────────────────────────────────
+
+interface LabState {
+  // Factor
+  factorName: string;
+
+  // Multi-file project
+  files: LabFile[];
+  activeFileId: string;
+
+  // Editor
+  activeTab: EditorTab;
+  notes: string;
+  preprocessConfig: PreprocessConfig;
+
+  // Editor settings
+  editorFontSize: number;
+  editorLineWrap: boolean;
+  editorStats: EditorStats;
+
+  // Validation
+  validationConfig: ValidationConfig;
+  validationStatus: ValidationStatus;
+  validationResult: ValidationResult | null;
+
+  // Context panel (right side: results + AI tabs)
+  contextPanelTab: ContextPanelTab;
+  contextPanelCollapsed: boolean;
+
+  // Console bottom panel
+  consolePanelOpen: boolean;
+
+  // Pyodide (browser Python runtime)
+  pyodideStatus: PyodideStatus;
+  pyodideError: string | null;
+  consoleOutput: ConsoleOutputLine[];
+
+  // Lint diagnostics count
+  lintErrorCount: number;
+
+  // AI messages
+  aiMessages: AIChatMessage[];
+
+  // Factor actions
+  setFactorName: (name: string) => void;
+
+  // File actions
+  setFileContent: (fileId: string, content: string) => void;
+  addFile: (name?: string) => void;
+  removeFile: (fileId: string) => void;
+  renameFile: (fileId: string, newName: string) => void;
+  setActiveFileId: (fileId: string) => void;
+  getActiveExpression: () => string;
+
+  // Editor actions
+  setActiveTab: (tab: EditorTab) => void;
+  setNotes: (notes: string) => void;
+  togglePreprocessStep: (step: keyof PreprocessConfig) => void;
+
+  // Editor settings actions
+  setEditorFontSize: (size: number) => void;
+  toggleEditorLineWrap: () => void;
+  setEditorStats: (stats: EditorStats) => void;
+
+  // Validation actions
+  setValidationConfig: (config: Partial<ValidationConfig>) => void;
+  setValidationStatus: (status: ValidationStatus) => void;
+  setValidationResult: (result: ValidationResult | null) => void;
+
+  // Context panel actions
+  setContextPanelTab: (tab: ContextPanelTab) => void;
+  setContextPanelCollapsed: (collapsed: boolean) => void;
+  openContextPanel: (tab: ContextPanelTab) => void;
+  toggleContextPanel: (tab: ContextPanelTab) => void;
+
+  // Console panel actions
+  setConsolePanelOpen: (open: boolean) => void;
+  toggleConsolePanel: () => void;
+
+  // Pyodide actions
+  setPyodideStatus: (status: PyodideStatus) => void;
+  setPyodideError: (error: string | null) => void;
+  appendConsoleOutput: (line: ConsoleOutputLine) => void;
+  clearConsoleOutput: () => void;
+
+  // Lint actions
+  setLintErrorCount: (count: number) => void;
+
+  // AI message actions
+  addAIMessage: (message: AIChatMessage) => void;
+  clearAIMessages: () => void;
+}
+
+// ─── Store ───────────────────────────────────────────────
+
+export const useLabStore = create<LabState>((set, get) => ({
+  // ── Defaults ──
+  factorName: "动量反转_v1",
+
+  files: initialFiles,
+  activeFileId: initialFiles[0].id,
+
+  activeTab: "code",
+  notes: "",
+  preprocessConfig: { ...DEFAULT_PREPROCESS_CONFIG },
+
+  editorFontSize: 13,
+  editorLineWrap: true,
+  editorStats: { line: 1, col: 1, chars: 0, lines: 1, fileName: "main.py" },
+
+  validationConfig: { ...DEFAULT_VALIDATION_CONFIG },
+  validationStatus: "idle",
+  validationResult: null,
+
+  contextPanelTab: "results",
+  contextPanelCollapsed: false,
+
+  consolePanelOpen: false,
+
+  pyodideStatus: "idle",
+  pyodideError: null,
+  consoleOutput: [],
+  lintErrorCount: 0,
+
+  aiMessages: [
+    {
+      id: "welcome",
+      role: "assistant",
+      content:
+        "你好! 我是 Alpha 因子研究顾问。可以帮你解读因子公式、分析 IC/IR 统计指标、诊断覆盖率问题。有什么想了解的?",
+      timestamp: Date.now(),
+    },
+  ],
+
+  // ── Factor Actions ──
+  setFactorName: (name) => set({ factorName: name }),
+
+  // ── File Actions ──
+  setFileContent: (fileId, content) =>
+    set((state) => ({
+      files: state.files.map((f) =>
+        f.id === fileId ? { ...f, content, isDirty: true } : f,
+      ),
+    })),
+
+  addFile: (name) => {
+    const state = get();
+    const existingNames = new Set(state.files.map((f) => f.name));
+    let finalName = name ?? "untitled_1.py";
+    if (!name) {
+      let i = 1;
+      while (existingNames.has(`untitled_${i}.py`)) i++;
+      finalName = `untitled_${i}.py`;
+    }
+    const newFile: LabFile = {
+      id: generateId(),
+      name: finalName,
+      content: "",
+      language: "python",
+      isDirty: false,
+    };
+    set({ files: [...state.files, newFile], activeFileId: newFile.id });
+  },
+
+  removeFile: (fileId) => {
+    const state = get();
+    if (state.files.length <= 1) return;
+    const idx = state.files.findIndex((f) => f.id === fileId);
+    const nextFiles = state.files.filter((f) => f.id !== fileId);
+    const nextActiveId =
+      state.activeFileId === fileId
+        ? nextFiles[Math.min(idx, nextFiles.length - 1)].id
+        : state.activeFileId;
+    set({ files: nextFiles, activeFileId: nextActiveId });
+  },
+
+  renameFile: (fileId, newName) =>
+    set((state) => ({
+      files: state.files.map((f) =>
+        f.id === fileId ? { ...f, name: newName } : f,
+      ),
+    })),
+
+  setActiveFileId: (fileId) => set({ activeFileId: fileId }),
+
+  getActiveExpression: () => {
+    const state = get();
+    return state.files.map((f) => f.content).join("\n\n");
+  },
+
+  // ── Editor Actions ──
+  setActiveTab: (tab) => set({ activeTab: tab }),
+  setNotes: (notes) => set({ notes }),
+  togglePreprocessStep: (step) =>
+    set((state) => ({
+      preprocessConfig: {
+        ...state.preprocessConfig,
+        [step]: !state.preprocessConfig[step],
+      },
+    })),
+
+  // ── Editor Settings Actions ──
+  setEditorFontSize: (size) =>
+    set({ editorFontSize: Math.min(18, Math.max(12, size)) }),
+  toggleEditorLineWrap: () =>
+    set((state) => ({ editorLineWrap: !state.editorLineWrap })),
+  setEditorStats: (stats) => set({ editorStats: stats }),
+
+  // ── Validation Actions ──
+  setValidationConfig: (config) =>
+    set((state) => ({
+      validationConfig: { ...state.validationConfig, ...config },
+    })),
+  setValidationStatus: (status) => set({ validationStatus: status }),
+  setValidationResult: (result) => set({ validationResult: result }),
+
+  // ── Context Panel Actions ──
+  setContextPanelTab: (tab) => set({ contextPanelTab: tab }),
+  setContextPanelCollapsed: (collapsed) =>
+    set({ contextPanelCollapsed: collapsed }),
+  openContextPanel: (tab) =>
+    set({ contextPanelTab: tab, contextPanelCollapsed: false }),
+  toggleContextPanel: (tab) => {
+    const state = get();
+    if (!state.contextPanelCollapsed && state.contextPanelTab === tab) {
+      set({ contextPanelCollapsed: true });
+    } else {
+      set({ contextPanelTab: tab, contextPanelCollapsed: false });
+    }
+  },
+
+  // ── Console Panel Actions ──
+  setConsolePanelOpen: (open) => set({ consolePanelOpen: open }),
+  toggleConsolePanel: () =>
+    set((state) => ({ consolePanelOpen: !state.consolePanelOpen })),
+
+  // ── Pyodide Actions ──
+  setPyodideStatus: (status) => set({ pyodideStatus: status }),
+  setPyodideError: (error) => set({ pyodideError: error }),
+  appendConsoleOutput: (line) =>
+    set((state) => ({ consoleOutput: [...state.consoleOutput, line] })),
+  clearConsoleOutput: () => set({ consoleOutput: [] }),
+
+  // ── Lint Actions ──
+  setLintErrorCount: (count) => set({ lintErrorCount: count }),
+
+  // ── AI Message Actions ──
+  addAIMessage: (message) =>
+    set((state) => ({ aiMessages: [...state.aiMessages, message] })),
+  clearAIMessages: () =>
+    set({
+      aiMessages: [
+        {
+          id: "welcome",
+          role: "assistant",
+          content:
+            "你好! 我是 Alpha 因子研究顾问。可以帮你解读因子公式、分析 IC/IR 统计指标、诊断覆盖率问题。有什么想了解的?",
+          timestamp: Date.now(),
+        },
+      ],
+    }),
+}));
diff --git a/apps/web/src/features/lab/types.ts b/apps/web/src/features/lab/types.ts

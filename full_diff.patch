+import { EditorToolbar } from "./editor-toolbar";
+import { EditorStatusBar } from "./editor-status-bar";
+import { buildExtensions, fontSizeExtension } from "./extensions/create-extensions";
+
+// ─── CodeMirror Wrapper ─────────────────────────────────
+
+export function CodeEditor() {
+  const containerRef = useRef<HTMLDivElement>(null);
+  const viewRef = useRef<import("@codemirror/view").EditorView | null>(null);
+
+  // Compartment refs for dynamic reconfiguration
+  const fontSizeCompRef = useRef<import("@codemirror/state").Compartment | null>(null);
+  const lineWrapCompRef = useRef<import("@codemirror/state").Compartment | null>(null);
+
+  // Multi-file state cache: fileId → EditorState snapshot
+  const stateCacheRef = useRef<Map<string, import("@codemirror/state").EditorState>>(new Map());
+
+  // Track current file id to detect switches
+  const currentFileIdRef = useRef(useLabStore.getState().activeFileId);
+
+  // Shared extensions ref (created once during init, reused for new files)
+  const sharedExtensionsRef = useRef<import("@codemirror/state").Extension[] | null>(null);
+
+  // Loading / error state
+  const [isLoading, setIsLoading] = useState(true);
+  const [initError, setInitError] = useState<string | null>(null);
+
+  // Retry counter to trigger re-mount
+  const [retryCount, setRetryCount] = useState(0);
+
+  // Open search panel callback for toolbar
+  const handleOpenSearch = useCallback(() => {
+    const view = viewRef.current;
+    if (!view) return;
+    import("@codemirror/search").then(({ openSearchPanel }) => {
+      openSearchPanel(view);
+    });
+  }, []);
+
+  // ── Initialize CodeMirror ──
+  useEffect(() => {
+    const container = containerRef.current;
+    if (!container) return;
+
+    let view: import("@codemirror/view").EditorView | null = null;
+    let destroyed = false;
+
+    async function init() {
+      const currentContainer = containerRef.current;
+      if (!currentContainer || destroyed) return;
+
+      try {
+        const [
+          cmView,
+          cmState,
+          cmPython,
+          cmAutocomplete,
+          cmCommands,
+          cmSearch,
+          cmLanguage,
+        ] = await Promise.all([
+          import("@codemirror/view"),
+          import("@codemirror/state"),
+          import("@codemirror/lang-python"),
+          import("@codemirror/autocomplete"),
+          import("@codemirror/commands"),
+          import("@codemirror/search"),
+          import("@codemirror/language"),
+        ]);
+
+        if (destroyed) return;
+
+        const { EditorView } = cmView;
+        const { highlightSelectionMatches } = await import("@codemirror/search");
+        const { EditorState, Compartment } = cmState;
+
+        // ── Compartments for dynamic settings ──
+        const fontSizeComp = new Compartment();
+        const lineWrapComp = new Compartment();
+        fontSizeCompRef.current = fontSizeComp;
+        lineWrapCompRef.current = lineWrapComp;
+
+        const currentFontSize = useLabStore.getState().editorFontSize;
+        const currentLineWrap = useLabStore.getState().editorLineWrap;
+
+        // ── Build extensions via factory ──
+        // Cast needed: CM6 Facet types are structurally incompatible with
+        // our looser CMModules interface (readonly KeyBinding[] vs any[]).
+        // Type safety is guaranteed at this call site by the dynamic imports.
+        const cmModules = {
+            EditorView,
+            lineNumbers: cmView.lineNumbers,
+            highlightActiveLine: cmView.highlightActiveLine,
+            highlightSpecialChars: cmView.highlightSpecialChars,
+            drawSelection: cmView.drawSelection,
+            highlightSelectionMatches,
+            keymap: cmView.keymap,
+            bracketMatching: cmLanguage.bracketMatching,
+            closeBrackets: cmAutocomplete.closeBrackets,
+            closeBracketsKeymap: cmAutocomplete.closeBracketsKeymap,
+            indentOnInput: cmLanguage.indentOnInput,
+            foldGutter: cmLanguage.foldGutter,
+            foldKeymap: cmLanguage.foldKeymap,
+            history: cmCommands.history,
+            historyKeymap: cmCommands.historyKeymap,
+            search: cmSearch.search,
+            searchKeymap: cmSearch.searchKeymap,
+            defaultKeymap: cmCommands.defaultKeymap,
+            indentWithTab: cmCommands.indentWithTab,
+            python: cmPython.python,
+            autocompletion: cmAutocomplete.autocompletion,
+        } as import("./extensions/create-extensions").CMModules;
+
+        const extensions = buildExtensions(
+          cmModules,
+          {
+            fontSizeComp,
+            lineWrapComp,
+            initialFontSize: currentFontSize,
+            initialLineWrap: currentLineWrap,
+            getWorker,
+            onDocChanged: (value) => {
+              const store = useLabStore.getState();
+              store.setFileContent(store.activeFileId, value);
+            },
+            onCursorChanged: (stats) => {
+              const store = useLabStore.getState();
+              const activeFile = store.files.find((f) => f.id === store.activeFileId);
+              store.setEditorStats({
+                ...stats,
+                fileName: activeFile?.name ?? "untitled.py",
+              });
+            },
+            onLintCount: (count) => {
+              useLabStore.getState().setLintErrorCount(count);
+            },
+            onTriggerValidation: () => {
+              labEvents.dispatchEvent(new Event(TRIGGER_VALIDATION));
+            },
+          },
+        );
+
+        sharedExtensionsRef.current = extensions;
+
+        // ── Create initial state from active file ──
+        const store = useLabStore.getState();
+        const activeFile = store.files.find((f) => f.id === store.activeFileId);
+
+        const state = EditorState.create({
+          doc: activeFile?.content ?? "",
+          extensions,
+        });
+
+        if (destroyed) return;
+
+        view = new EditorView({ state, parent: currentContainer });
+        viewRef.current = view;
+        currentFileIdRef.current = store.activeFileId;
+
+        // ── Push initial stats ──
+        const doc = view.state.doc;
+        store.setEditorStats({
+          line: 1,
+          col: 1,
+          chars: doc.length,
+          lines: doc.lines,
+          fileName: activeFile?.name ?? "main.py",
+        });
+
+        // ── Acquire shared Pyodide worker for linting ──
+        try {
+          acquireWorker();
+        } catch {
+          // Linting won't work, but the editor is still functional
+        }
+
+        setIsLoading(false);
+        setInitError(null);
+      } catch (err) {
+        if (!destroyed) {
+          const message = err instanceof Error ? err.message : String(err);
+          setInitError(message);
+          setIsLoading(false);
+        }
+      }
+    }
+
+    setIsLoading(true);
+    setInitError(null);
+    init();
+
+    return () => {
+      destroyed = true;
+      view?.destroy();
+      viewRef.current = null;
+      releaseWorker();
+    };
+  }, [retryCount]);
+
+  // ── React to active file changes (multi-file switching) ──
+  const activeFileId = useLabStore((s) => s.activeFileId);
+  useEffect(() => {
+    const view = viewRef.current;
+    if (!view || !sharedExtensionsRef.current) return;
+    if (activeFileId === currentFileIdRef.current) return;
+
+    // Save current file's state to cache
+    stateCacheRef.current.set(currentFileIdRef.current, view.state);
+
+    // Load or create state for new file
+    const cached = stateCacheRef.current.get(activeFileId);
+    if (cached) {
+      view.setState(cached);
+    } else {
+      const store = useLabStore.getState();
+      const file = store.files.find((f) => f.id === activeFileId);
+
+      import("@codemirror/state").then(({ EditorState }) => {
+        const newState = EditorState.create({
+          doc: file?.content ?? "",
+          extensions: sharedExtensionsRef.current!,
+        });
+        view.setState(newState);
+      });
+    }
+
+    currentFileIdRef.current = activeFileId;
+  }, [activeFileId]);
+
+  // ── React to store changes for font size ──
+  const fontSize = useLabStore((s) => s.editorFontSize);
+  useEffect(() => {
+    const view = viewRef.current;
+    const comp = fontSizeCompRef.current;
+    if (!view || !comp) return;
+
+    import("@codemirror/view").then(({ EditorView: EV }) => {
+      view.dispatch({
+        effects: comp.reconfigure(fontSizeExtension(EV, fontSize)),
+      });
+    });
+  }, [fontSize]);
+
+  // ── React to store changes for line wrap ──
+  const lineWrap = useLabStore((s) => s.editorLineWrap);
+  useEffect(() => {
+    const view = viewRef.current;
+    const comp = lineWrapCompRef.current;
+    if (!view || !comp) return;
+
+    import("@codemirror/view").then(({ EditorView: EV }) => {
+      view.dispatch({
+        effects: comp.reconfigure(lineWrap ? EV.lineWrapping : []),
+      });
+    });
+  }, [lineWrap]);
+
+  // ── Error State ──
+  if (initError) {
+    return (
+      <div
+        data-slot="code-editor"
+        className="h-full flex flex-col overflow-hidden"
+      >
+        <EditorToolbar onOpenSearch={handleOpenSearch} />
+        <div className="flex-1 min-h-0 flex items-center justify-center bg-[#faf9f7]">
+          <div className="text-center space-y-3 px-6">
+            <div className="w-10 h-10 mx-auto rounded-full bg-mine-accent-red/10 flex items-center justify-center">
+              <svg
+                className="w-5 h-5 text-mine-accent-red"
+                fill="none"
+                viewBox="0 0 24 24"
+                stroke="currentColor"
+                strokeWidth={2}
+              >
+                <path
+                  strokeLinecap="round"
+                  strokeLinejoin="round"
+                  d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"
+                />
+              </svg>
+            </div>
+            <p className="text-sm font-medium text-mine-text">
+              编辑器加载失败
+            </p>
+            <p className="text-xs text-mine-muted max-w-[280px]">
+              {initError}
+            </p>
+            <button
+              onClick={() => setRetryCount((c) => c + 1)}
+              className="px-3 py-1.5 text-xs font-medium bg-mine-nav-active text-white rounded-lg hover:bg-mine-nav-active/90 transition-colors"
+            >
+              重新加载
+            </button>
+          </div>
+        </div>
+        <EditorStatusBar />
+      </div>
+    );
+  }
+
+  return (
+    <div
+      data-slot="code-editor"
+      className="h-full flex flex-col overflow-hidden"
+    >
+      {/* Toolbar */}
+      <EditorToolbar onOpenSearch={handleOpenSearch} />
+
+      {/* Loading Skeleton */}
+      {isLoading && (
+        <div className="flex-1 min-h-0 bg-[#faf9f7] flex">
+          {/* Gutter skeleton */}
+          <div className="w-[52px] shrink-0 bg-[#f5f3ef] border-r border-[#e0ddd8]">
+            {Array.from({ length: 20 }, (_, i) => (
+              <div
+                key={i}
+                className="h-[20px] flex items-center justify-end pr-2"
+              >
+                <div
+                  className="w-3 h-2 rounded-sm bg-mine-border/40 animate-pulse"
+                  style={{ animationDelay: `${i * 30}ms` }}
+                />
+              </div>
+            ))}
+          </div>
+          {/* Content skeleton */}
+          <div className="flex-1 p-4 space-y-1.5">
+            {[85, 60, 45, 70, 30, 55, 80, 40, 65, 50, 35, 75, 45, 60].map(
+              (w, i) => (
+                <div
+                  key={i}
+                  className="h-[18px] rounded bg-mine-border/20 animate-pulse"
+                  style={{
+                    width: `${w}%`,
+                    animationDelay: `${i * 40}ms`,
+                  }}
+                />
+              ),
+            )}
+          </div>
+        </div>
+      )}
+
+      {/* CodeMirror Container */}
+      <div
+        ref={containerRef}
+        className={`flex-1 min-h-0 overflow-hidden [&_.cm-editor]:h-full [&_.cm-scroller]:!overflow-auto ${isLoading ? "hidden" : ""}`}
+      />
+
+      {/* Status Bar */}
+      <EditorStatusBar />
+    </div>
+  );
+}

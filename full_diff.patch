+        ol: ({ children }) => (
+          <ol className="text-xs text-mine-text leading-[1.6] mb-2 ml-4 list-decimal">
+            {children}
+          </ol>
+        ),
+        li: ({ children }) => <li className="mb-0.5">{children}</li>,

@@ -0,0 +1,51 @@
+"use client";
+
+import { useCallback } from "react";
+import { useLabStore } from "../store/use-lab-store";
+import { usePyodideWorker } from "./use-pyodide-worker";
+import { generateMockValidation, hashCode } from "../data/mock-validation";
+
+/**
+ * Hook that triggers a validation run:
+ * 1. Execute the user's Python code via Pyodide (real execution)
+ * 2. Generate mock validation results from the expression hash
+ *
+ * Python errors are displayed in Console Output (stderr) but do NOT
+ * block mock validation results from being generated.
+ */
+export function useRunValidation() {
+  const setValidationStatus = useLabStore((s) => s.setValidationStatus);
+  const setValidationResult = useLabStore((s) => s.setValidationResult);
+  const clearConsoleOutput = useLabStore((s) => s.clearConsoleOutput);
+  const { execute: executePython } = usePyodideWorker();
+
+  return useCallback(async () => {
+    const expression = useLabStore.getState().getActiveExpression();
+
+    setValidationStatus("running");
+    setValidationResult(null);
+    clearConsoleOutput();
+
+    // Auto-open console panel so user sees Python output
+    useLabStore.getState().setConsolePanelOpen(true);
+
+    // 1. Real Python execution via Pyodide
+    try {
+      await executePython(expression);
+    } catch {
+      // Python errors are already captured in console output via stderr.
+      // We don't block the validation flow.
+    }
+
+    // 2. Generate mock validation results (keep existing 8-step analysis)
+    try {
+      const seed = hashCode(expression);
+      const result = generateMockValidation(seed);
+
+      setValidationResult(result);
+      setValidationStatus("completed");
+    } catch {
+      setValidationStatus("error");
+    }
+  }, [setValidationStatus, setValidationResult, clearConsoleOutput, executePython]);
+}

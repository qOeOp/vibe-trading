+      el.style.height = "auto";
+      el.style.height = `${Math.min(el.scrollHeight, 80)}px`;
+    },
+    [],
+  );
+
+  // Determine which categories to show
+  const visibleCategories = showAllPills
+    ? PROMPT_CATEGORIES
+    : PROMPT_CATEGORIES.slice(0, 2);
+
+  return (
